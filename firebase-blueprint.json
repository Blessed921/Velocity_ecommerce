{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user profile on the platform",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "wishlist": { "type": "array", "items": { "type": "string" }, "description": "Array of Sneaker IDs" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role", "createdAt"]
    },
    "Sneaker": {
      "title": "Sneaker",
      "description": "A sneaker product listing",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "brand": { "type": "string" },
        "price": { "type": "number" },
        "description": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "sizes": { "type": "array", "items": { "type": "number" } },
        "categories": { "type": "array", "items": { "type": "string" } },
        "stock": { "type": "integer" },
        "isNewArrival": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "brand", "price", "stock", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer purchase order",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "sneakerId": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "size": { "type": "number" },
              "quantity": { "type": "integer" }
            }
          }
        },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "paid", "shipped", "delivered", "cancelled"] },
        "shippingAddress": {
          "type": "object",
          "properties": {
            "fullName": { "type": "string" },
            "street": { "type": "string" },
            "city": { "type": "string" },
            "state": { "type": "string" },
            "phone": { "type": "string" }
          }
        },
        "paystackReference": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "totalAmount", "status", "createdAt"]
    },
    "Review": {
      "title": "Review",
      "description": "Product review by a user",
      "type": "object",
      "properties": {
        "sneakerId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "integer", "minimum": 1, "maximum": 5 },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["sneakerId", "userId", "rating", "comment", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "In-app notifications for users",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["new_arrival", "restock", "order_update"] },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "message", "type", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/sneakers/{sneakerId}": {
      "schema": "Sneaker",
      "description": "Available stock of sneakers"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "User feedback on sneakers"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User specific notifications"
    }
  }
}
